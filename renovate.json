{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "labels": [
    "dependencies"
  ],
  "allowedCommands": [
    "^bash scripts/renovate-plugin-sync\\.sh$"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update linked Claude plugin tags and immutable commit pins in marketplace.json",
      "managerFilePatterns": [
        "/^\\.claude-plugin/marketplace\\.json$/"
      ],
      "matchStrings": [
        "\"source\"\\s*:\\s*\\{\\s*\"source\"\\s*:\\s*\"github\",\\s*\"repo\"\\s*:\\s*\"(?<packageName>[^\"]+)\",\\s*\"ref\"\\s*:\\s*\"(?<currentValue>v?\\d+\\.\\d+\\.\\d+(?:[-+][0-9A-Za-z.-]+)?)\",\\s*\"sha\"\\s*:\\s*\"(?<currentDigest>[a-f0-9]{40})\"\\s*\\}"
      ],
      "datasourceTemplate": "github-tags",
      "versioningTemplate": "semver-coerced"
    },
    {
      "customType": "regex",
      "description": "Update immutable commit pins for linked Claude plugins following a branch",
      "managerFilePatterns": [
        "/^\\.claude-plugin/marketplace\\.json$/"
      ],
      "matchStrings": [
        "\"source\"\\s*:\\s*\\{\\s*\"source\"\\s*:\\s*\"github\",\\s*\"repo\"\\s*:\\s*\"(?<packageName>[^\"]+)\",\\s*\"ref\"\\s*:\\s*\"(?<currentValue>main|master)\",\\s*\"sha\"\\s*:\\s*\"(?<currentDigest>[a-f0-9]{40})\"\\s*\\}"
      ],
      "datasourceTemplate": "github-digest"
    }
  ],
  "packageRules": [
    {
      "matchManagers": [
        "custom.regex"
      ],
      "matchFileNames": [
        ".claude-plugin/marketplace.json"
      ],
      "addLabels": [
        "marketplace"
      ],
      "commitMessageTopic": "linked Claude plugin {{depName}}"
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "GitHub Actions",
      "addLabels": [
        "ci"
      ]
    }
  ],
  "postUpgradeTasks": {
    "commands": [
      "bash scripts/renovate-plugin-sync.sh"
    ],
    "fileFilters": [
      ".claude-plugin/marketplace.json",
      ".agents/**",
      "plugins/**"
    ],
    "executionMode": "branch"
  }
}
