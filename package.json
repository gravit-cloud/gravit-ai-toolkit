{
  "name": "gravit-ai-toolkit",
  "version": "1.0.0",
  "description": "Kuratierter Plugin-Marketplace für Claude Code und Codex, bereitgestellt von Gravit Cloud.",
  "license": "MIT",
  "author": {
    "name": "Gravit Cloud"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gravit-cloud/gravit-ai-toolkit.git"
  },
  "homepage": "https://github.com/gravit-cloud/gravit-ai-toolkit",
  "keywords": [
    "agent-skills",
    "skills",
